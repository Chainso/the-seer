SEER_APP_NAME=seer-backend
SEER_APP_ENV=development
SEER_LOG_LEVEL=INFO
SEER_HOST=0.0.0.0
SEER_PORT=8000
SEER_API_PREFIX=/api/v1
# Use `fuseki` when backend runs in docker-compose.yml.
# Use `localhost` when backend runs on host and db services run via docker-compose.db.yml.
SEER_FUSEKI_HOST=fuseki
SEER_FUSEKI_PORT=3030
SEER_FUSEKI_DATASET=ds
SEER_FUSEKI_USERNAME=
SEER_FUSEKI_PASSWORD=
SEER_FUSEKI_TIMEOUT_SECONDS=5.0
# Use `clickhouse` when backend runs in docker-compose.yml.
# Use `localhost` when backend runs on host and db services run via docker-compose.db.yml.
SEER_CLICKHOUSE_HOST=clickhouse
SEER_CLICKHOUSE_PORT=8123
SEER_CLICKHOUSE_DATABASE=seer
SEER_CLICKHOUSE_USER=seer
SEER_CLICKHOUSE_PASSWORD=seer
SEER_CLICKHOUSE_TIMEOUT_SECONDS=5.0
SEER_CLICKHOUSE_MIGRATIONS_DIR=migrations/clickhouse
SEER_PROCESS_MINING_MAX_EVENTS=5000
SEER_PROCESS_MINING_MAX_RELATIONS=40000
SEER_PROCESS_MINING_MAX_TRACES_PER_HANDLE=100
SEER_ROOT_CAUSE_MAX_EVENTS=10000
SEER_ROOT_CAUSE_MAX_RELATIONS=120000
SEER_ROOT_CAUSE_MAX_TRACES_PER_INSIGHT=30
SEER_DEPENDENCY_TIMEOUT_SECONDS=1.0
SEER_PROPHET_METAMODEL_PATH=../prophet/prophet.ttl
SEER_OPENAI_BASE_URL=http://localhost:8787/v1
SEER_OPENAI_MODEL=gemini-3-flash-preview
SEER_OPENAI_API_KEY=
SEER_OPENAI_TIMEOUT_SECONDS=45.0
SEER_COPILOT_QUERY_ROW_LIMIT=100
