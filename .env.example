# Host Gemini CLI passthrough for containerized backend.
# Optional overrides; by default compose uses:
#   ${NVM_DIR:-${HOME}/.nvm}/versions/node/${SEER_GEMINI_NODE_VERSION:-v24.10.0}
SEER_GEMINI_HOST_NODE_DIR=
SEER_GEMINI_NODE_VERSION=v24.10.0
SEER_GEMINI_HOST_AUTH_DIR=
