SEER_BACKEND_PORT=8000
SEER_UI_PORT=3000
SEER_FUSEKI_PORT=3030
SEER_CLICKHOUSE_HTTP_PORT=8123
SEER_CLICKHOUSE_NATIVE_PORT=9000
FUSEKI_ADMIN_PASSWORD=admin
CLICKHOUSE_DB=seer
CLICKHOUSE_USER=seer
CLICKHOUSE_PASSWORD=seer

# Optional: host Gemini CLI passthrough for containerized backend.
# Used by docker-compose.gemini-host.yml
# Example bin dir from `dirname "$(which gemini)"`.
# SEER_GEMINI_HOST_BIN_DIR=/home/you/.nvm/versions/node/v24.10.0/bin
# Example auth dir if already authenticated on host.
# SEER_GEMINI_HOST_AUTH_DIR=/home/you/.gemini
SEER_GEMINI_HOST_BIN_DIR=
SEER_GEMINI_HOST_AUTH_DIR=
