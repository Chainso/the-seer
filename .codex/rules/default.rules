# Seer monorepo: common development and verification tooling.

prefix_rule(
    pattern = ["uv", "sync"],
    decision = "allow",
    justification = "Allow dependency sync for local development",
    match = [
        "uv sync",
        "uv sync --extra dev",
        "uv sync --directory seer-backend --extra dev",
    ],
    not_match = [
        "uv pip install fastapi",
    ],
)

prefix_rule(
    pattern = ["uv", "run"],
    decision = "allow",
    justification = "Allow uv run with flexible flags and delegated subcommands",
    match = [
        "uv run pytest -q",
        "uv run --directory seer-backend ruff check .",
        "uv run --project seer-backend python -m pytest tests -q",
        "uv run --no-sync --directory seer-backend uvicorn seer_backend.main:app --reload",
    ],
)

prefix_rule(
    pattern = [["pytest", "ruff", "uvicorn"]],
    decision = "allow",
    justification = "Allow direct invocation of common backend tooling",
    match = [
        "pytest -q",
        "ruff check .",
        "uvicorn seer_backend.main:app --reload",
    ],
    not_match = [
        "python -m pytest -q",
    ],
)

prefix_rule(
    pattern = [[".venv/bin/pytest", ".venv/bin/ruff", ".venv/bin/uvicorn", "seer-backend/.venv/bin/pytest", "seer-backend/.venv/bin/ruff", "seer-backend/.venv/bin/uvicorn"]],
    decision = "allow",
    justification = "Allow direct invocation from local virtual environments",
    match = [
        ".venv/bin/pytest -q",
        "seer-backend/.venv/bin/pytest -q",
        "seer-backend/.venv/bin/uvicorn seer_backend.main:app --reload",
    ],
    not_match = [
        ".venv/bin/python -m pytest",
        "seer-backend/.venv/bin/python -m pytest",
    ],
)

prefix_rule(
    pattern = [["./scripts/dev-up.sh", "./scripts/dev-down.sh", "scripts/dev-up.sh", "scripts/dev-down.sh"]],
    decision = "allow",
    justification = "Allow project dev environment script entrypoints",
    match = [
        "./scripts/dev-up.sh",
        "./scripts/dev-down.sh",
        "scripts/dev-up.sh",
    ],
    not_match = [
        "./scripts/other.sh",
    ],
)

prefix_rule(
    pattern = [["bash", "sh"], ["./scripts/dev-up.sh", "./scripts/dev-down.sh", "scripts/dev-up.sh", "scripts/dev-down.sh"]],
    decision = "allow",
    justification = "Allow running project dev scripts through bash or sh",
    match = [
        "bash ./scripts/dev-up.sh",
        "sh ./scripts/dev-down.sh",
    ],
    not_match = [
        "bash ./scripts/other.sh",
    ],
)

prefix_rule(
    pattern = ["uv", "add"],
    decision = "allow",
    justification = "Allow adding dependencies with uv",
    match = [
        "uv add fastapi",
        "uv add --dev pytest",
        "uv add --directory seer-backend pydantic",
    ],
    not_match = [
        "uv remove fastapi",
    ],
)
